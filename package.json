{
  "name": "yamo-app-mobile",
  "private": true,
  "version": "0.1.0",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "start:online": "powershell -Command \"Remove-Item Env:EXPO_OFFLINE -ErrorAction SilentlyContinue; Remove-Item Env:EXPO_NO_DOCTOR -ErrorAction SilentlyContinue; expo start --clear\"",
    "start:offline": "powershell -Command \"$env:EXPO_OFFLINE='1'; $env:EXPO_NO_DOCTOR='1'; expo start\"",
    "typecheck": "tsc --noEmit",
    "test:quality": "node --test tests/quality/auth-flow.test.mjs tests/quality/security-hardening.test.mjs tests/quality/alignment-expansion.test.mjs",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "setup:android": "powershell -ExecutionPolicy Bypass -File scripts/setup-android.ps1 -Persist",
    "check:bucket": "node scripts/check-supabase-bucket.mjs photos",
    "create:bucket": "node scripts/create-supabase-bucket.mjs photos",
    "create:bucket:kyc": "node scripts/create-supabase-bucket.mjs kyc-docs",
    "create:bucket:chat": "node scripts/create-supabase-bucket.mjs chat-media",
    "supabase:init": "powershell -ExecutionPolicy Bypass -File scripts/apply-supabase-init.ps1",
    "supabase:init:force": "powershell -ExecutionPolicy Bypass -File scripts/apply-supabase-init.ps1 -AllowErrors",
    "supabase:rls": "powershell -ExecutionPolicy Bypass -File scripts/apply-rls.ps1",
    "supabase:schema": "powershell -ExecutionPolicy Bypass -File scripts/apply-rls.ps1 -WithSchema",
    "sentry:upload-sourcemaps": "npx sentry-expo-upload-sourcemaps dist",
    "eas-build-post-install": "bash ./scripts/eas-post-install.sh"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-navigation/bottom-tabs": "7.10.1",
    "@react-navigation/native": "7.1.28",
    "@react-navigation/native-stack": "7.2.0",
    "@sentry/react-native": "~6.10.0",
    "@supabase/supabase-js": "^2.95.3",
    "base64-arraybuffer": "^1.0.2",
    "expo": "~52.0.49",
    "expo-asset": "~11.0.5",
    "expo-av": "~15.0.2",
    "expo-build-properties": "~0.13.2",
    "expo-device": "~7.0.2",
    "expo-file-system": "~18.0.12",
    "expo-image-picker": "~16.0.6",
    "expo-linear-gradient": "~14.0.0",
    "expo-linking": "~7.0.2",
    "expo-location": "~18.0.0",
    "expo-notifications": "~0.29.14",
    "expo-status-bar": "~2.0.0",
    "expo-video": "~2.0.6",
    "expo-video-thumbnails": "~9.0.3",
    "expo-web-browser": "~14.0.1",
    "lucide-react-native": "^0.469.0",
    "react": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-iap": "^12.16.0",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@react-native-community/cli": "^20.0.1",
    "@types/react": "~18.3.12",
    "typescript": "~5.8.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-av"
        ],
        "listUnknownPackages": false
      }
    }
  },
  "volta": {
    "node": "20.19.0"
  }
}
