{
  "expo": {
    "name": "Yamo",
    "slug": "yamo-app",
    "scheme": "yamo",
    "version": "0.1.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "icon": "./assets/logo_yamo.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-1242x2436.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Yamo utilise votre position pour les profils \u00e0 proximit\u00e9."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "package": "com.gdramane.ouattara.yamoapp"
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "733b0be9-2861-4be4-b674-e2bbe80e30a0"
      }
    }
  }
}
