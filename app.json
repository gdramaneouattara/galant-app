{
  "expo": {
    "name": "Galant",
    "slug": "galant-app",
    "scheme": "galant",
    "version": "0.1.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "icon": "./assets/icon (2).png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-1242x2436.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Galant utilise votre position pour vous proposer des profils à proximité et faciliter les rencontres locales.",
        "NSCameraUsageDescription": "L'accès à l'appareil photo permet de prendre des photos de profil et de réaliser la vérification d'identité (KYC).",
        "NSPhotoLibraryUsageDescription": "Accédez à votre galerie pour sélectionner et partager vos plus belles photos sur votre profil Galant.",
        "NSPhotoLibraryAddUsageDescription": "Permet à Galant d'enregistrer des photos dans votre bibliothèque.",
        "PHPhotoLibraryPreventAutomaticLimitedAccessAlert": true,
        "NSMicrophoneUsageDescription": "Le micro est nécessaire pour enregistrer le son de vos vidéos de statut et envoyer des messages vocaux.",
        "UIUserInterfaceStyle": "Light",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.ouattara.galant",
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS",
        "CAMERA",
        "RECORD_AUDIO",
        "VIBRATE",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "READ_MEDIA_IMAGES",
        "READ_MEDIA_VIDEO",
        "READ_MEDIA_AUDIO",
        "com.android.vending.BILLING"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon (2).png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.ouattara.galant",
      "versionCode": 16
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "@react-native-firebase/app",
      "@react-native-firebase/auth",
      "@react-native-firebase/messaging",
      "expo-asset",
      "expo-image-picker",
      [
        "expo-notifications",
        {
          "color": "#FF6B6B"
        }
      ],
      "expo-location",
      "expo-av",
      "react-native-iap",
      "@sentry/react-native/expo",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "buildToolsVersion": "35.0.0",
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "kotlinVersion": "1.9.25"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ],
      "expo-video"
    ],
    "extra": {
      "eas": {
        "projectId": "e450e548-4bcb-47b5-8594-613ea04969eb"
      }
    },
    "owner": "gdramane.ouattara"
  }
}
