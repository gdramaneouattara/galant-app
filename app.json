{
  "expo": {
    "name": "Yamo",
    "slug": "yamo-app",
    "scheme": "yamo",
    "version": "0.1.0",
    "newArchEnabled": true,
    "orientation": "portrait",
    "icon": "./assets/logo_yamo.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-1242x2436.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Yamo utilise votre position pour les profils à proximité.",
        "UIUserInterfaceStyle": "Light",
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.konan.yamo"
    },
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "POST_NOTIFICATIONS"
      ],
      "package": "com.konan.yamo",
      "versionCode": 3,
      "notification": {
        "color": "#FF6B6B"
      }
    },
    "platforms": [
      "ios",
      "android"
    ],
    "plugins": [
      "expo-asset",
      "expo-notifications",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "733b0be9-2861-4be4-b674-e2bbe80e30a0"
      }
    }
  }
}
