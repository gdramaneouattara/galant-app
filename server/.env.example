# --- CONFIGURATION SERVEUR YAMO ---

# Port d'écoute (8787 est utilisé par l'app mobile par défaut)
PORT=8787

# URL de votre projet Supabase ( Dashboard > Settings > API )
SUPABASE_URL=https://votre-id-projet.supabase.co

# CLÉ SERVICE ROLE ( Dashboard > Settings > API > service_role )
# IMPORTANT : Utilisez bien la clé 'service_role' et non 'anon' car le serveur a besoin de droits admin.
SUPABASE_SERVICE_ROLE_KEY=votre_cle_service_role_secrete

# Token d'accès Expo pour les notifications push
# ( Dashboard Expo > Project Settings > Access Tokens )
EXPO_PUSH_ACCESS_TOKEN=votre_access_token_expo

# Origines autorisées pour le CORS (Mettez '*' pour le dev, ou votre URL Render en prod)
ALLOWED_ORIGINS=*

# URL de redirection pour les paiements / deep linking
PAYMENT_CHECKOUT_URL=yamo://payment-callback

# Mode d'exécution
NODE_ENV=development
