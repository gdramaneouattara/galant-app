# --- CONFIGURATION SERVEUR GALANT ---

# Port d'écoute (8787 est utilisé par l'app mobile par défaut)
PORT=8787

# Token d'accès Expo pour les notifications push
# ( Dashboard Expo > Project Settings > Access Tokens )
EXPO_PUSH_ACCESS_TOKEN=votre_access_token_expo

# Origines autorisées pour le CORS (Mettez '*' pour le dev, ou votre URL Render en prod)
ALLOWED_ORIGINS=*

# URL de redirection pour les paiements / deep linking
PAYMENT_CHECKOUT_URL=galant://payment-callback
PAYSTACK_CALLBACK_URL=galant://payment-callback

# Apple App Store Server API (paiements iOS via App Store / carte bancaire)
APPLE_ISSUER_ID=votre_issuer_id_apple
APPLE_KEY_ID=votre_key_id_apple
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
IOS_BUNDLE_ID=com.ouattara.galant

# Google Play (paiements Android via carte bancaire dans Google Play)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
ANDROID_PACKAGE_NAME=com.ouattara.galant

# Mode d'exécution
NODE_ENV=development
